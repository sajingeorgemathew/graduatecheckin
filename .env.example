NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

TICKET_TOKEN_SECRET=

# CHECKIN-09B ticket-distribution row-signing secret. Server-only, minimum
# 32 random bytes, and MUST be different from TICKET_TOKEN_SECRET. Never use
# the NEXT_PUBLIC_ prefix and never commit the value.
#   Generate with: openssl rand -base64 32
TICKET_DISTRIBUTION_SECRET=

# Event code of the graduation event that imports and ticket operations
# target. Server-only. Local development uses the mock event GRAD-2026-DEV.
ACTIVE_GRADUATION_EVENT_CODE=GRAD-2026-DEV

# ENABLE_DEV_IMPORTS was removed in CHECKIN-04. Excel imports now require
# an authenticated administrator in every environment.

ALLOW_DESTRUCTIVE_DEV_RESET=false
DEV_RESET_CONFIRMATION=
MOCK_EVENT_CODE=GRAD-2026-DEV
